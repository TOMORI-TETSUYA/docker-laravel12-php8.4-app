# ================================================================
# .env.docker.example — Docker Compose 用の変数集 (見本)
# ----------------------------------------------------------------
# このファイルは「Docker だけで使う設定値のひな形」です。
# コピーして `.env` にリネームすると、docker-compose.yml から
# `${変数名}` という形で自動的に読み込まれます。
#
# ★ 使い方 ★
#   1) このファイルを `.env` という名前でコピーする
#        cp .env.docker.example .env
#   2) 下の値を自分のプロジェクトに合わせて書き換える
#   3) `docker compose up -d --build` を実行
#
# ★ Laravel の .env との違い ★
#   - このファイル         = プロジェクトルートに置く、Docker 専用
#   - laravel_app/.env     = Laravel 本体用 (entrypoint.sh が自動生成)
#
#   両者は別物なので混同しないよう注意してください!
#
# ★ 量産 (新しい Laravel 12 プロジェクト) の時 ★
#   このファイルとルートの Dockerfile / docker-compose.yml は
#   そのままコピーして使えます。変えるのはこのファイルの値だけ。
# ================================================================


# ================================================================
# 【必須】プロジェクト識別
# ================================================================

# プロジェクト名 (英数字とハイフンのみ)
# docker-compose のコンテナ名の接頭辞に使われます。
# 例: taskflow → taskflow_web / taskflow_db / taskflow_phpmyadmin
COMPOSE_PROJECT_NAME=taskflow


# ================================================================
# 【必須】フォルダ構成
# ----------------------------------------------------------------
# Laravel 本体と公開フォルダの『フォルダ名』をここで指定します。
# 別のプロジェクトで名前を変える時はここを書き換えるだけで OK。
# ================================================================

# Laravel 本体 (非公開) のフォルダ名
# 例: laravel_app / backend / api / src
LARAVEL_DIR=laravel_app

# ドキュメントルート (= ブラウザに公開するフォルダ) の名前
# 例: task-manager / public_html / www / frontend
PUBLIC_DIR=task-manager


# ================================================================
# 【必須】公開ポート (ホスト PC 側)
# ----------------------------------------------------------------
# `localhost:PORT` でアクセスできるポート番号です。
# 他のアプリと競合する時は違う番号に変えてください。
# ================================================================

# Web アプリ本体 (Apache + Laravel 12)
WEB_PORT=8080

# phpMyAdmin (DB 管理画面)
PMA_PORT=8081

# MariaDB (DB サーバー) - ホスト PC から直接繋ぎたい場合
DB_PORT=3306


# ================================================================
# 【必須】データベース設定
# ----------------------------------------------------------------
# MariaDB コンテナの初期ユーザー設定。
# 初回起動時にこの値で DB とユーザーが自動作成されます。
#
# ⚠️ 本番では必ず強いパスワードに変更してください!
# ================================================================

# MariaDB の root ユーザーパスワード
DB_ROOT_PASSWORD=root

# アプリが使うデータベース名
DB_DATABASE=taskflow

# アプリが使うユーザー名 (root 以外を推奨)
DB_USERNAME=taskflow_user

# 上記ユーザーのパスワード
DB_PASSWORD=taskflow_pass


# ================================================================
# 【必須】PHP / Laravel 設定
# ----------------------------------------------------------------
# Dockerfile の ARG に渡される値です。
# ================================================================

# PHP のバージョン (Laravel 12 は 8.2 以上。8.4 は安定版でおすすめ)
PHP_VERSION=8.4

# タイムゾーン
TZ=Asia/Tokyo

# アップロード上限 (M = メガバイト)
PHP_UPLOAD_MAX=64M

# PHP メモリ上限
PHP_MEMORY_LIMIT=512M


# ================================================================
# 【任意】Laravel アプリの起動モード
# ----------------------------------------------------------------
# entrypoint.sh がコンテナ起動時に laravel_app/.env に
# 書き込む値です。ローカルは local / 本番は production。
# ================================================================

APP_NAME=T-TaskFlow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080


# ================================================================
# 【任意】追加サービス (使う時だけ書く)
# ================================================================

# Redis を使う場合のポート
# REDIS_PORT=6379

# Mailhog を使う場合のポート
# MAILHOG_WEB_PORT=8025
# MAILHOG_SMTP_PORT=1025
